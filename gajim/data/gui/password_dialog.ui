<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <requires lib="gtk" version="4.0"/>
  <object class="GtkBox" id="pass_box">
    <property name="halign">center</property>
    <property name="orientation">vertical</property>
    <property name="spacing">6</property>
    <child>
      <object class="GtkLabel" id="header">
        <property name="name">header</property>
        <property name="margin-bottom">6</property>
        <property name="wrap">1</property>
        <property name="max-width-chars">30</property>
        <style>
          <class name="large-header"/>
        </style>
      </object>
    </child>
    <child>
      <object class="GtkLabel" id="message_label">
        <property name="justify">center</property>
        <property name="wrap">1</property>
        <property name="max-width-chars">30</property>
      </object>
    </child>
    <child>
      <object class="GtkImage">
        <property name="icon-name">dialog-password-symbolic</property>
      </object>
    </child>
    <child>
      <object class="GtkEntry" id="pass_entry">
        <property name="width-request">200</property>
        <property name="focusable">1</property>
        <property name="has-focus">1</property>
        <property name="visibility">0</property>
        <property name="activates-default">1</property>
        <property name="input-purpose">password</property>
        <property name="input-hints">GTK_INPUT_HINT_NO_SPELLCHECK | GTK_INPUT_HINT_NONE</property>
      </object>
    </child>
    <child>
      <object class="GtkCheckButton" id="save_pass_checkbutton">
        <property name="visible">0</property>
        <property name="label" translatable="1">Save Password</property>
        <property name="focusable">1</property>
        <property name="halign">start</property>
        <property name="use-underline">1</property>
      </object>
    </child>
    <child>
      <object class="GtkBox">
        <property name="margin-top">12</property>
        <property name="spacing">6</property>
        <child>
          <object class="GtkButton" id="cancel_button">
            <property name="label" translatable="1">_Cancel</property>
            <property name="focusable">1</property>
            <property name="use-underline">1</property>
            <signal name="clicked" handler="_on_cancel" swapped="no"/>
          </object>
        </child>
        <child>
          <object class="GtkButton" id="ok_button">
            <property name="label" translatable="1">_Log In</property>
            <property name="focusable">1</property>
            <property name="use-underline">1</property>
            <signal name="clicked" handler="_on_ok" swapped="no"/>
            <style>
              <class name="suggested-action"/>
            </style>
          </object>
        </child>
      </object>
    </child>
    <child>
      <object class="GtkLabel" id="keyring_hint">
        <property name="visible">0</property>
        <property name="label" translatable="1">Install a keyring to store passwords on your system.</property>
        <property name="wrap">1</property>
        <property name="max-width-chars">30</property>
        <property name="xalign">0</property>
        <style>
          <class name="dim-label"/>
        </style>
      </object>
    </child>
  </object>
</interface>
