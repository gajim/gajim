<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <requires lib="gtk" version="4.0"/>
  <object class="GtkPaned" id="paned">
    <property name="shrink-start-child">0</property>
    <property name="resize-start-child">0</property>
    <property name="focusable">1</property>
    <property name="position">250</property>
    <property name="position-set">1</property>
    <property name="start-child">
      <object class="AdwToolbarView">
        <child type="top">
          <object class="AdwHeaderBar">
            <property name="show-back-button">False</property>
            <property name="show-end-title-buttons">False</property>
            <property name="show-title">True</property>
            <property name="title-widget">
            <object class="GtkBox">
              <property name="orientation">horizontal</property>
              <property name="spacing">12</property>
              <child>
                <object class="GtkLabel" id="header_bar_label">
                  <property name="ellipsize">end</property>
                  <property name="halign">start</property>
                  <property name="hexpand">true</property>
                  <style>
                    <class name="title-2"/>
                  </style>
                </object>
              </child>
              <child>
                <object class="GtkButton">
                  <property name="tooltip-text" translatable="yes">Workspace settings…</property>
                  <property name="valign">center</property>
                  <property name="action-name">win.edit-workspace</property>
                  <property name="action-target">&apos;&apos;</property>
                  <child>
                    <object class="GtkImage">
                      <property name="icon-name">preferences-system-symbolic</property>
                    </object>
                  </child>
                </object>
              </child>
              <style>
                <class name="chat-page-left-header-bar"/>
              </style>
            </object>
            </property>
          </object>
        </child>
        <property name="content">
          <object class="GtkGrid">
            <property name="vexpand">1</property>
            <child>
              <object class="GtkBox" id="chat_page_header">
                <property name="spacing">12</property>
                <child>
                  <object class="GtkSearchEntry" id="search_entry">
                    <property name="hexpand">true</property>
                    <property name="placeholder-text">Search…</property>
                  </object>
                </child>
                <child>
                  <object class="ChatFilter" id="chat_filter" />
                </child>
                <child>
                  <object class="GtkMenuButton" id="start_chat_menu_button">
                    <property name="tooltip-text">Start Chat…</property>
                    <child>
                      <object class="GtkImage">
                        <property name="icon-name">feather-plus-symbolic</property>
                      </object>
                    </child>
                    <style>
                      <class name="suggested-action"/>
                    </style>
                  </object>
                </child>
                <layout>
                  <property name="column">0</property>
                  <property name="row">0</property>
                </layout>
                <style>
                  <class name="chat-page-header"/>
                </style>
              </object>
            </child>
            <child>
              <object class="GtkScrolledWindow" id="list_scrolled">
                <property name="visible">True</property>
                <property name="can-focus">True</property>
                <child>
                  <object class="GtkViewport">
                    <property name="visible">True</property>
                    <property name="can-focus">False</property>
                    <child>
                      <object class="GtkStack" id="list_stack">
                        <property name="visible">True</property>
                        <property name="can-focus">False</property>
                        <child>
                          <placeholder/>
                        </child>
                        <child>
                          <placeholder/>
                        </child>
                      </object>
                    </child>
                  </object>
                </child>
                <style>
                  <class name="no-border"/>
                </style>
                <layout>
                  <property name="column">0</property>
                  <property name="row">1</property>
                </layout>
              </object>
            </child>
            <style>
              <class name="middle-grid"/>
            </style>
          </object>
        </property>
      </object>
    </property>
    <property name="end-child">
      <object class="AdwToolbarView" id="right_toolbar_view">
        <child type="top">
          <object class="AdwHeaderBar">
            <property name="show-back-button">False</property>
            <property name="show-start-title-buttons">False</property>
            <property name="show-title">True</property>
            <property name="title-widget">
              <object class="ChatBanner" id="chat_banner" />
            </property>
          </object>
        </child>
        <property name="content">
          <object class="GtkGrid" id="right_grid">
            <child>
              <placeholder/>
            </child>
          </object>
        </property>
      </object>
    </property>
  </object>
</interface>
