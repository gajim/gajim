<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <requires lib="gtk" version="4.0"/>
  <object class="GtkListStore" id="account_liststore">
    <columns>
      <column type="gchararray"/>
      <column type="gchararray"/>
    </columns>
  </object>
  <object class="GtkBox" id="select_account_box">
    <property name="orientation">vertical</property>
    <property name="spacing">18</property>
    <child>
      <object class="GtkLabel">
        <property name="label" translatable="1">Export Chat History</property>
        <property name="wrap">1</property>
        <property name="max-width-chars">40</property>
        <style>
          <class name="large-header"/>
        </style>
      </object>
    </child>
    <child>
      <object class="GtkLabel">
        <property name="label" translatable="1">Please select one of your accounts.
Gajim will export all messages from the selected account to a directory of your choice.</property>
        <property name="justify">center</property>
        <property name="wrap">1</property>
        <property name="max-width-chars">40</property>
        <style>
          <class name="dim-label"/>
        </style>
      </object>
    </child>
    <child>
      <object class="GtkGrid">
        <property name="halign">center</property>
        <property name="row-spacing">18</property>
        <property name="column-spacing">12</property>
        <child>
          <object class="GtkLabel">
            <property name="halign">end</property>
            <property name="label" translatable="1">Account</property>
            <style>
              <class name="dim-label"/>
            </style>
            <layout>
              <property name="column">0</property>
              <property name="row">0</property>
            </layout>
          </object>
        </child>
        <child>
          <object class="GtkComboBox" id="account_combo">
            <property name="width-request">250</property>
            <property name="model">account_liststore</property>
            <property name="id-column">0</property>
            <property name="active-id">-1</property>
            <signal name="changed" handler="_on_account_changed" swapped="no"/>
            <child>
              <object class="GtkCellRendererText"/>
              <attributes>
                <attribute name="text">1</attribute>
              </attributes>
            </child>
            <layout>
              <property name="column">1</property>
              <property name="row">0</property>
            </layout>
          </object>
        </child>
        <child>
          <object class="GtkLabel">
            <property name="halign">end</property>
            <property name="label" translatable="1">Directory</property>
            <style>
              <class name="dim-label"/>
            </style>
            <layout>
              <property name="column">0</property>
              <property name="row">1</property>
            </layout>
          </object>
        </child>
        <child>
          <object class="GtkFileChooserButton" id="file_chooser_button">
            <property name="width-request">250</property>
            <property name="visible">True</property>
            <property name="can-focus">False</property>
            <property name="action">select-folder</property>
            <property name="preview-widget-active">False</property>
            <property name="title" translatable="1">Choose History Export Directory</property>
            <signal name="file-set" handler="_on_file_set" swapped="no"/>
            <layout>
              <property name="column">1</property>
              <property name="row">1</property>
            </layout>
          </object>
        </child>
      </object>
    </child>
  </object>
</interface>
